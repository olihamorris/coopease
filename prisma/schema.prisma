generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id         String   @id @default(cuid())
  memberNo   String   @unique
  firstName  String
  lastName   String
  phone      String
  email      String?
  address    String?
  status     String   @default("ACTIVE")
  dateJoined DateTime @default(now())
}